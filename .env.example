#--------------------------------------------------------------------------
# Agentic AI Analytics Platform - Consolidated Configuration (Example)
#--------------------------------------------------------------------------

# Antigravity/System
ANTIGRAVITY_SKILLS_PATH=.agents/skills
ANTIGRAVITY_DEBUG=true

# Database Connection Reference
LOCAL_DATABASE_URL=postgresql://your_db_user:CHANGE_ME_LOCAL_DATABASE_PASSWORD@localhost:5432/agentic_ai
NEON_DATABASE_URL=postgresql://your_neon_user:CHANGE_ME_NEON_DATABASE_PASSWORD@your_neon_host.neon.tech/neondb?sslmode=require

# GCP Deployment Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=your-gcp-region
BACKEND_SERVICE_NAME=report-backend
FRONTEND_SERVICE_NAME=report-frontend

# Google BigQuery Configuration
BIGQUERY_DATASET=analytics

# Database credentials for deployment
SPRING_DATASOURCE_URL=jdbc:postgresql://your_neon_host.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_DEPLOYMENT_DATABASE_PASSWORD

# Security User
SECURITY_ADMIN_USERNAME=admin
SECURITY_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SECURITY_ADMIN_ROLE=USER

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# JWT MOCK_FALLBACK_TOKEN for DEV environment (Use a randomly generated token in production)
MOCK_FALLBACK_TOKEN=CHANGE_ME_JWT_MOCK_TOKEN
